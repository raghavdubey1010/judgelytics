# Judgelytics Backend Configuration
# Copy this file to .env and fill in your actual values

# Database Configuration
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/judgelytics

# JWT Security
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ML Models Directory
ML_MODELS_DIR=../ml_pipeline/saved_models/

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Application
DEBUG=False
RELOAD=False
