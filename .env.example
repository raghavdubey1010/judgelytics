# Judgelytics Backend Environment Configuration

# Application Settings
APP_NAME=Judgelytics API
APP_VERSION=1.0.0
DEBUG=False
RELOAD=True

# Database Configuration — SQLite (zero setup)
DATABASE_URL=sqlite+aiosqlite:///./judgelytics.db

# Security
SECRET_KEY=judgelytics-super-secret-jwt-key-2026-change-in-prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS — allow frontend served via Live Server or file://
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173,http://127.0.0.1:3000

# ML Models Directory (relative to project root)
ML_MODELS_DIR=ml_pipeline/saved_models

# Groq API — free tier (get key from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI API — paste your key here when ready (takes priority over Groq)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic API (Claude)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Server
HOST=0.0.0.0
PORT=8000
